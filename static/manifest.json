{
  "manifest_version": 2,

  "name": "@humi_bookmark",
  "description": "Fumio Murakami",
  "version": "0.0.2",
  "minimum_chrome_version": "79",

  "icons": {
    "128": "img/icon_128.png"
  },

  "permissions": [
    "*://*.ameba.jp/*",
    "*://*.cloudfront.net/*",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "declarativeContent",
    "storage",
    "alarms"
  ],

  "page_action": {
    "default_title": "@humi_bookmark",
    "default_popup": "html/popup.html",
    "default_icon": {
      "128": "img/icon_128.png"
    }
  },

  "event_rules": [
    {
      "event": "declarativeContent.onPageChanged",
      "actions": [
        {
          "type": "declarativeContent.ShowPageAction"
        }
      ],
      "conditions": [
        {
          "type": "declarativeContent.PageStateMatcher",
          "pageUrl": {
            "urlMatches": "(http|https)\\:\\/\\/((vcard|\\.*stat100)\\.ameba\\.jp|.*\\.cloudfront\\.net).*"
          }
        }
      ]
    }
  ],

  "background": {
    "scripts": ["js/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["https://vcard.ameba.jp/*"],
      "js": ["js/content.js"],
      "web_accessible_resources": ["js/content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "web_accessible_resources": ["js/injected.js"],

  "options_page": "html/options.html"
}
