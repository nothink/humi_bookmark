{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist/js",
    "removeComments": false,

    "strict": true,
    "noImplicitAny": true,

    "moduleResolution": "node",
    "baseUrl": ".",
    "jsx": "react",
    "lib": ["es2015", "dom"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true
  },
  "exclude": [
    "node_modules"
  ],
  "typedocOptions": {
    "mode": "modules",
    "out": "docs"
  }
}
