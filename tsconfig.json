{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "commonjs",
    "target": "es6",
    "sourceMap": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "dist/js",
    "allowJs": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "removeComments": true,
    "noImplicitAny": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "typeRoots": ["node_modules/@types"]
  },
  "formatCodeOptions": {
    "indentSize": 2
  },
  "include": ["src/*.ts", "src/**/*.ts", "test/*.ts", "test/**/*.ts"]
}
